# 데이터베이스 (MariaDB)
DB_URL=jdbc:mariadb://localhost:3308/charging?characterEncoding=UTF-8
DB_USERNAME=your_db_username
DB_PASSWORD=your_db_password

# 카카오 소셜 로그인
# https://developers.kakao.com 에서 발급
KAKAO_CLIENT_ID=your_kakao_client_id
KAKAO_REDIRECT_URI=http://localhost:8080/kakao/callback

# 네이버 소셜 로그인
# https://developers.naver.com 에서 발급
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret
NAVER_REDIRECT_URI=http://localhost:8080/naver/callback

# 공공 충전소 API 키
# https://www.data.go.kr 에서 발급
CHARGING_API_KEY=your_charging_api_key
